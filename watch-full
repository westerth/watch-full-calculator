function calcDose(weight, item) {
let total = weight * item.dose;
let warning = "";

if (item.min && total < item.min) {
total = item.min;
warning = "Min dose";
}

if (item.max && total > item.max) {
total = item.max;
warning = "Max dose";
}

let unit = item.unit.includes("/kg") ? item.unit.replace("/kg","") : item.unit;

return { total: total, unit: unit, warning: warning };
}

